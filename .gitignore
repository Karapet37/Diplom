# Environment and local tooling
.env
.venv/
.idea/
.vscode/

# Python cache/build artifacts
__pycache__/
*.py[cod]
*.so
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Web UI
webapp/node_modules/
webapp/dist/

# Runtime databases and snapshots
*.db
*.db-*
*.sqlite3
*.sqlite3-*
data/*.db
data/*.db-*
data/*.sqlite3
data/*.sqlite3-*
data/autonomous_graph_snapshot.json

# Runtime-generated graph/session artifacts
data/project_backups/*.json
data/sessions/*.json
!data/sessions/.gitkeep
memory/sessions/*.txt
!memory/sessions/.gitkeep
memory/graphs/*.json
!memory/graphs/.gitkeep
memory/personalities/proposals/*.json
!memory/personalities/proposals/.gitkeep
memory/graph_history/**
!memory/graph_history/.gitkeep

# Generated exports and reports
reports/
data/profile_exports/

# Large local models
models/*.gguf
models/**/*.gguf

# TLS certificates
infra/nginx/certs/*.pem
infra/nginx/certs/*.key
infra/nginx/certs/*.crt

# OS files
.DS_Store
